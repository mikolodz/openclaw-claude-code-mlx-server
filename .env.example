# Core model setup
MODEL_PATH=lmstudio-community/GLM-4.7-Flash-MLX-4bit
# Optional override for LiteLLM model name. Default is openai/{MODEL_PATH}.
PROXY_MODEL_ID=openai/lmstudio-community/GLM-4.7-Flash-MLX-4bit

# Server ports and host
MLX_HOST=127.0.0.1
MLX_PORT=8080
PROXY_PORT=4000
PROXY_STARTUP_WAIT_SECONDS=2.0

# Prompt cache (global; session/conversation ID is ignored for lookup)
PROMPT_CACHE_MAX_SIZE=24
PROMPT_CACHE_TTL_SECONDS=1800
# Block-based index for O(blocks) prefix lookup (default off). Set CACHE_USE_BLOCK_INDEX=true to enable.
# PROMPT_CACHE_BLOCK_SIZE=16
# CACHE_USE_BLOCK_INDEX=false
# CACHE_SESSION_PARTITIONING is ignored; cache is always global for multi-agent / OpenClaw.

# KV cache and generation
MAX_KV_SIZE=196608
KV_GROUP_SIZE=64
# Set KV_BITS=OFF if your model errors on KV cache quantization.
KV_BITS=OFF

# Sampler defaults used when client request does not pass params.
# Active defaults below are tuned for GLM-4.7-Flash (stable, low randomness).
DEFAULT_TEMPERATURE=0.7
DEFAULT_TOP_P=1.0
DEFAULT_TOP_K=0
DEFAULT_MIN_P=0.01
DEFAULT_REPETITION_PENALTY=1.00
DEFAULT_REPETITION_CONTEXT_SIZE=256
DEFAULT_MAX_TOKENS=16384

# ---- Preset: Qwen3 (general chat, more creative) ----
# Uncomment and use if MODEL_PATH points to a Qwen3 model.
# DEFAULT_TEMPERATURE=0.6
# DEFAULT_TOP_P=0.95
# DEFAULT_TOP_K=50
# DEFAULT_MIN_P=0.0
# DEFAULT_REPETITION_PENALTY=1.05
# DEFAULT_REPETITION_CONTEXT_SIZE=256
# DEFAULT_MAX_TOKENS=2048

# ---- Preset: Qwen3 (coding, more deterministic) ----
# DEFAULT_TEMPERATURE=0.2
# DEFAULT_TOP_P=0.9
# DEFAULT_TOP_K=40
# DEFAULT_MIN_P=0.05
# DEFAULT_REPETITION_PENALTY=1.03
# DEFAULT_REPETITION_CONTEXT_SIZE=512
# DEFAULT_MAX_TOKENS=4096

# Logging
ENABLE_REQUEST_LOGGING=true
LOG_ROOT=logs

# Optional: set VLM_CACHE_DEBUG=true to log first 64 prompt token IDs in cache-session logs.
# Use to diff subsequent VLM requests and verify if prefix tokenization is stable (cache hits).
# VLM_CACHE_DEBUG=false

# ---- VLM (vision) troubleshooting ----
# If VLM crashes with Metal "commit command buffer with uncommitted encoder" on Apple Silicon,
# the server now syncs MLX and PyTorch MPS before generation. If it still crashes, install
# mlx-vlm without the torch extra for a slower but more stable image path:
#   pip uninstall torch torchvision; pip install mlx-vlm
