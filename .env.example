# Core model setup
MODEL_PATH=lmstudio-community/GLM-4.7-Flash-MLX-4bit
# Optional override for LiteLLM model name. Default is openai/{MODEL_PATH}.
PROXY_MODEL_ID=openai/lmstudio-community/GLM-4.7-Flash-MLX-4bit

# Server ports and host
MLX_HOST=127.0.0.1
MLX_PORT=8080
PROXY_PORT=4000
PROXY_STARTUP_WAIT_SECONDS=2.0

# Prompt cache
PROMPT_CACHE_MAX_SIZE=24
PROMPT_CACHE_TTL_SECONDS=1800

# KV cache and generation
MAX_KV_SIZE=196608
KV_GROUP_SIZE=64
# Set KV_BITS=OFF if your model errors on KV cache quantization.
KV_BITS=OFF

DEFAULT_TEMPERATURE=0.1
DEFAULT_TOP_P=0.9
DEFAULT_TOP_K=40
DEFAULT_MIN_P=0.05
DEFAULT_REPETITION_PENALTY=1.08
DEFAULT_REPETITION_CONTEXT_SIZE=256
DEFAULT_MAX_TOKENS=2048

# Logging
ENABLE_REQUEST_LOGGING=true
LOG_ROOT=logs
