# Copy to .env and adjust to your machine.
# Defaults below are tuned for Qwen3.5/3.6 on Apple Silicon and verified to work
# out of the box.  Uncomment an alternate preset at the bottom for other models.

# ============================================================================
# Model
# ============================================================================

# HuggingFace repo or local path.  Unresolvable repos are snapshot_downloaded
# automatically via huggingface_hub (keeps only *.json / *.safetensors / *.model /
# *.tiktoken / *.py / *.jinja).  For VLM models, mlx-vlm must be installed.
MODEL_PATH=mlx-community/Qwen3.5-35B-A3B-4bit

# Forces the chat-template family when auto-detection is ambiguous.
# Options: qwen3 | glm4 | generic.  Leave qwen3 for any Qwen3.x including VLM variants.
MODEL_FAMILY=qwen3

# How the LiteLLM proxy exposes the model to clients (e.g. pi, OpenClaw, Claude Code).
# `openai/local` is a stable label that client configs can pin without caring
# about the underlying MODEL_PATH.
PROXY_MODEL_ID=openai/local

# Forward `preserve_thinking=True` to the chat template so prior assistant
# <think>…</think> blocks stay in history.  Critical for Qwen3.5/3.6 multi-turn
# reasoning quality and for cache hit-rate (template probed at startup;
# unsupported → kwarg is silently dropped, so safe to leave on).
PRESERVE_THINKING=true

# ============================================================================
# Network
# ============================================================================

MLX_HOST=127.0.0.1
MLX_PORT=8080
PROXY_PORT=4000
PROXY_STARTUP_WAIT_SECONDS=2.0

# ============================================================================
# Prompt cache (KV reuse)
# ============================================================================
# Cache is always global for multi-agent / OpenClaw — per-session partitioning
# is bookkept for diagnostics only (CACHE_SESSION_PARTITIONING below).

PROMPT_CACHE_MAX_ENTRIES_GLOBAL=16
PROMPT_CACHE_MAX_ENTRIES_PER_SESSION=2

# 0 = never expire (recommended for long agentic runs).  Positive = seconds.
PROMPT_CACHE_TTL_SECONDS=0
PROMPT_CACHE_SESSION_MAX_IDLE_SECONDS=0

# Pre-render canonicalisation of volatile fields (message IDs, Inbound Context
# block, sub-agent Stats runtime) so retries and per-turn drift hit cache.
# Required for any real agentic traffic — do not disable.
CACHE_CANONICALIZE_TOOL_CONTEXT=true
CACHE_SESSION_PARTITIONING=true

# ============================================================================
# KV cache / generation
# ============================================================================

# Upper bound on context length the server will serve (tokens).  Larger values
# allocate more GPU memory up front; 262144 handles full 256K-context runs.
MAX_KV_SIZE=262144
KV_GROUP_SIZE=64

# KV-cache quantisation.
#   KV_BITS=OFF                → no quantisation (highest quality, most memory).
#   KV_BITS=3.5 + turboquant   → near-lossless, large memory savings (default).
#   KV_BITS=4 + uniform        → classic linear quantisation.
# Set KV_BITS=OFF first if you see garbled output on an unfamiliar model.
KV_BITS=3.5
KV_QUANT_SCHEME=turboquant

# Token index at which KV quantisation kicks in.  Earlier tokens stay FP16
# for prompt-region quality.  Only used with turboquant.
QUANTIZED_KV_START=16000

# ============================================================================
# Sampler defaults (used when the client does not supply the field)
# ============================================================================
# Active preset: Qwen3.5 / Qwen3.6 reasoning models.

DEFAULT_TEMPERATURE=0.6
DEFAULT_TOP_P=0.95
DEFAULT_TOP_K=20
DEFAULT_MIN_P=0.00
DEFAULT_REPETITION_PENALTY=1.00
DEFAULT_REPETITION_CONTEXT_SIZE=256
DEFAULT_MAX_TOKENS=32768
DEFAULT_ENABLE_THINKING=true

# ---- Alternate preset: Qwen3 coder (more deterministic) ----
# DEFAULT_TEMPERATURE=0.7
# DEFAULT_TOP_P=1.0
# DEFAULT_TOP_K=40
# DEFAULT_MIN_P=0.05
# DEFAULT_REPETITION_PENALTY=1.00
# DEFAULT_REPETITION_CONTEXT_SIZE=256
# DEFAULT_MAX_TOKENS=16384
# DEFAULT_ENABLE_THINKING=false

# ---- Alternate preset: GLM-4.7-Flash ----
# MODEL_PATH=lmstudio-community/GLM-4.7-Flash-MLX-4bit
# MODEL_FAMILY=glm4
# DEFAULT_TEMPERATURE=0.7
# DEFAULT_TOP_P=1.0
# DEFAULT_TOP_K=0
# DEFAULT_MIN_P=0.01
# DEFAULT_REPETITION_PENALTY=1.00
# DEFAULT_REPETITION_CONTEXT_SIZE=256
# DEFAULT_MAX_TOKENS=16384

# ============================================================================
# Diagnostics
# ============================================================================

# Per-request JSON traces in logs/<date>/cache-session-<hash>.log.
ENABLE_REQUEST_LOGGING=true
LOG_ROOT=logs

# Extra diagnostics for VLM cache behaviour: logs the first 64 canonical
# prompt tokens per request and prints a 🔬 one-liner with match type, KV
# offset, and rest-length.  Noisy; enable only when debugging a regression.
VLM_CACHE_DEBUG=false

# ============================================================================
# Safety nets
# ============================================================================

# Per-request wall-clock deadline on generation (seconds).  A runaway decode
# releases model_lock at this boundary and returns finish_reason="length".
# 0 disables the watchdog entirely (legacy behaviour).
# GENERATION_WATCHDOG_SECONDS=600

# Startup safety check that rejects cache-key normalisation that would delete
# more than 10% of the original prompt.  Off by default (adds per-request
# latency); turn on when iterating on _scrub_cache_key / _canonicalize_messages.
# CACHE_NORM_SAFETY_CHECK=false

# ============================================================================
# VLM troubleshooting
# ============================================================================
# If the VLM path crashes on Apple Silicon with
#   "commit command buffer with uncommitted encoder"
# the server already syncs MLX and PyTorch MPS before generation.  If it still
# crashes, reinstall mlx-vlm without the torch extra for a slower but more
# stable image path:
#     pip uninstall torch torchvision
#     pip install mlx-vlm
