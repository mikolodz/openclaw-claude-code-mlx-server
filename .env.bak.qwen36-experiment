MODEL_PATH=mlx-community/Qwen3.5-27B-4bit
#MODEL_PATH=mlx-community/Qwen3.5-27B-Claude-4.6-Opus-Distilled-MLX-4bit
MODEL_FAMILY=qwen3
PROXY_MODEL_ID=openai/local

MLX_HOST=127.0.0.1
MLX_PORT=8080
PROXY_PORT=4000
PROXY_STARTUP_WAIT_SECONDS=2.0

PROMPT_CACHE_MAX_ENTRIES_GLOBAL=16
PROMPT_CACHE_MAX_ENTRIES_PER_SESSION=2
PROMPT_CACHE_TTL_SECONDS=0
PROMPT_CACHE_SESSION_MAX_IDLE_SECONDS=0

# Default context size for agentic systems
# MAX_KV_SIZE=131072
MAX_KV_SIZE=262144
KV_GROUP_SIZE=64
# Set to OFF if generation crashes due to unsupported KV quantization.
KV_BITS=3.5
KV_QUANT_SCHEME=turboquant
QUANTIZED_KV_START=16000

# Proposed for Qwen3.5-35B-A3B
DEFAULT_TEMPERATURE=0.6
DEFAULT_TOP_P=0.95
DEFAULT_TOP_K=20
DEFAULT_MIN_P=0.00
DEFAULT_REPETITION_PENALTY=1.00
DEFAULT_REPETITION_CONTEXT_SIZE=256
DEFAULT_MAX_TOKENS=16384
DEFAULT_ENABLE_THINKING=true

